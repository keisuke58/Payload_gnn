<kml xmlns="http://www.opengis.net/kml/2.2" xmlns:gx="http://www.google.com/kml/ext/2.2">
<Document>
  <name>Moon &amp; Mars Mission Ground Tracks</name>
  <description>Sub-spacecraft ground tracks from JPL Horizons data.
  Shows the point on Earth directly below each spacecraft.</description>
  <open>1</open>
  <Style id="s_Mars_2020_Perseverance">
    <LineStyle><color>ff3333ff</color><width>3</width></LineStyle>
  </Style>
  <Style id="s_Mars_2020_Perseverance_pt">
    <IconStyle><color>ff3333ff</color><scale>0.8</scale></IconStyle>
  </Style>
  <Folder>
    <name>Mars 2020 (Perseverance)</name>
    <description><![CDATA[NASA Mars 2020 — Perseverance rover + Ingenuity helicopter
Launch: 2020-07-30 from Cape Canaveral
Mars landing: 2021-02-18 Jezero Crater
Max distance: ~204,000,000 km]]></description>
